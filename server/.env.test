# Local Docker Postgres for integration tests. Override via env if running CI
# with a different connection.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/truckflow_test

JWT_SECRET=test_jwt_secret_not_used_in_prod
NODE_ENV=test

# Stripe + email are stubbed in tests — leaving keys unset is fine; the code
# already silently skips when keys are missing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
APP_URL=http://localhost:3001
API_URL=http://localhost:3000
